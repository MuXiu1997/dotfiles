typeset -U path fpath

# { Helpers
  function file_exists() {
    [[ -f "$1" ]] && return 0 || return 1
  }

  function file_readable_then_source() {
    [[ -r "$1" ]] && source "$1"
  }

  function command_exists() {
    type "$1" &>/dev/null && return 0 || return 1
  }
# }

# { Config Directories
  # Directory for managed zshenv configuration files
  _zshenv_d="${HOME}/.config/zsh/zshenv.d"
  # Directory for local zshenv configuration files (not managed by chezmoi)
  _zshenv_local_d="${HOME}/.config/zsh/zshenv.local.d"
# }

# { XDG
  # Exports: XDG_CONFIG_HOME, XDG_CACHE_HOME, XDG_DATA_HOME, XDG_STATE_HOME, XDG_RUNTIME_DIR
  file_readable_then_source "${_zshenv_d}/xdg.zsh"
# }

# { Zsh
  export ZDOTDIR="${XDG_CONFIG_HOME}/zsh"

  # Directory for managed zshrc configuration files
  _zshrc_d="${ZDOTDIR}/zshrc.d"

  file_readable_then_source "${_zshrc_d}/setup-history.zsh"
# }

# { Homebrew
  # Updates: path, fpath
  # Exports: LDFLAGS, CPPFLAGS (Darwin only)
  file_readable_then_source "${_zshenv_d}/homebrew.zsh"
# }

# { Zoxide
  export _ZO_DATA_DIR="$XDG_DATA_HOME"
# }

# { Ranger
  export RANGER_LOAD_DEFAULT_RC="FALSE"
# }

# { Git
  export GIT_CONFIG_GLOBAL="${XDG_CONFIG_HOME}/git/config"
# }

# { Lazygit
  export LG_CONFIG_FILE="${XDG_CONFIG_HOME}/lazygit/config.yml"
# }

# { Less
  export LESS="Rmc"
# }

# { Wget
  export WGETRC="${XDG_CONFIG_HOME}/wgetrc"
# }

# { Nvm
  export NVM_DIR="${XDG_DATA_HOME}/nvm"
# }

# { Npm
  export NPM_CONFIG_USERCONFIG="${XDG_CONFIG_HOME}/npm/npmrc"
  path=("${XDG_DATA_HOME}/npm/bin" $path)
# }

# { Ni
  export NI_CONFIG_FILE="${XDG_CONFIG_HOME}/ni/nirc"
# }

# { Pnpm
  path=("${XDG_DATA_HOME}/pnpm/bin" $path)
# }

# { Deno
  export DENO_DIR="${XDG_CACHE_HOME}/deno"
  export DENO_INSTALL_ROOT="${XDG_DATA_HOME}/deno/bin"
  path=("${DENO_INSTALL_ROOT}" $path)
# }

# { Go
  export GOPATH="${XDG_DATA_HOME}/go"
  export GOBIN="${GOPATH}/bin"
  export GOMODCACHE="${GOPATH}/pkg/mod"
  export GOPROXY="https://goproxy.cn,direct"
  path=("${GOBIN}" $path)
# }

# { Poetry
  export POETRY_CONFIG_DIR="${XDG_CONFIG_HOME}/poetry"
  export POETRY_DATA_DIR="${XDG_DATA_HOME}/poetry"
  export POETRY_CACHE_DIR="${XDG_CACHE_HOME}/poetry"
  export POETRY_VIRTUALENVS_IN_PROJECT=true
# }

# { Gradle
  export GRADLE_USER_HOME="${XDG_DATA_HOME}/gradle"
# }

# { Maven
  export MAVEN_CONFIG="${XDG_CONFIG_HOME}/maven/settings.xml"
  file_exists "${MAVEN_CONFIG}" && alias mvn="mvn -s ${MAVEN_CONFIG}"
# }

# { Rust
  export RUSTUP_HOME="${XDG_DATA_HOME}/rustup"
  export CARGO_HOME="${XDG_DATA_HOME}/cargo"
  path=("${CARGO_HOME}/bin" $path)
# }

# { JetBrains
  export JETBRAINS_BIN="${XDG_DATA_HOME}/jetbrains/bin"
  path=("${JETBRAINS_BIN}" $path)
# }

# { Local Docker Compose
  export LOCAL_DOCKER_COMPOSE_DIR="${HOME}/Projects/@local-docker-compose"
# }

# { GitHub
  # Exports: GITHUB_TOKEN
  file_readable_then_source "${_zshenv_d}/github.zsh"
# }

# { Local
  # Load local zsh configurations not managed by chezmoi
  if [[ -d "$_zshenv_local_d" ]]; then
    for config_file in "$_zshenv_local_d"/*.zsh(N); do
      file_readable_then_source "$config_file"
    done
  fi
# }

export USER_LOCAL_BIN="${HOME}/.local/bin"
path=("${USER_LOCAL_BIN}" $path)
fpath=("${XDG_DATA_HOME}/zsh/site-functions" $fpath)
